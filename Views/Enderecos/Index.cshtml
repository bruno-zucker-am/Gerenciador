@model IEnumerable<ProjetosDB.Models.Endereco>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Meus Endereços</h4>
        <div class="d-flex gap-2">
            <a asp-action="ExportarCsv" class="btn btn-secondary btn-sm">Exportar CSV</a>
            <a asp-action="Create" class="btn btn-primary btn-sm">+ Novo</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light-custom text-center py-5">
            <p class="mb-1">Nenhum endereço encontrado.</p>
            <small>Clique em "+ Novo" para cadastrar.</small>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>CEP</th>
                        <th>Logradouro</th>
                        <th>Nº</th>
                        <th>Complemento</th>
                        <th>Bairro</th>
                        <th>Cidade/UF</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Cep</td>
                            <td>@item.Logradouro</td>
                            <td>@item.Numero</td>
                            <td>@item.Complemento</td>
                            <td>@item.Bairro</td>
                            <td>@item.Cidade / @item.Uf</td>
                            <td class="align-middle">
                                <div class="d-flex justify-content-center gap-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary px-3">Editar</a>

                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0"
                                          onsubmit="return confirm('Excluir este endereço?');">
                                        <button type="submit" class="btn btn-sm btn-danger px-3">Excluir</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
