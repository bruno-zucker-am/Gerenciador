@model ProjetosDB.Models.Endereco

<div class="container mt-4">
    <div class="card-form">
        <h3 class="mb-4">Novo Endereço</h3>
        <form asp-action="Create">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">CEP</label>
                    <input asp-for="Cep" id="cep" class="form-control" placeholder="00000000" maxlength="8" required />
                </div>
                <div class="col-md-7 mb-3">
                    <label class="form-label">Logradouro</label>
                    <input asp-for="Logradouro" id="logradouro" class="form-control" readonly required />
                </div>
                <div class="col-md-2 mb-3">
                    <label class="form-label">Número</label>
                    <input asp-for="Numero" class="form-control" required />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Complemento (Opcional)</label>
                    <input asp-for="Complemento" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Bairro</label>
                    <input asp-for="Bairro" id="bairro" class="form-control" readonly required />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Cidade</label>
                    <input asp-for="Cidade" id="cidade" class="form-control" readonly required />
                </div>
                <div class="col-md-2 mb-3">
                    <label class="form-label">UF</label>
                    <input asp-for="Uf" id="uf" class="form-control" readonly required />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success w-100">SALVAR ENDEREÇO</button>
                <a asp-action="Index" class="btn btn-secondary w-100">CANCELAR</a>
            </div>
        </form>
    </div>
</div>
