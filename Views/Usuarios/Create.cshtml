@model ProjetosDB.Models.Usuario

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-8 col-md-5 col-lg-4 card-form">
            <h3 class="text-center mb-4">Criar Conta</h3>

            <form asp-action="Create">
                <div class="mb-3">
                    <label class="form-label">Nome Completo</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Usuário (Login)</label>
                    <input asp-for="Login" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Senha</label>
                    <div class="input-group">
                        <input asp-for="Senha" id="pwdCreate" type="password" class="form-control" required />
                        <button class="btn" type="button" onclick="togglePass('pwdCreate', 'iconCreate')">
                            <i id="iconCreate" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success mb-3">Salvar Cadastro</button>
                </div>
            </form>

            <hr class="my-4">

            <div class="d-grid">
                <a asp-action="Login" class="btn btn-secondary">
                    ← Voltar ao Login
                </a>
            </div>
        </div>
    </div>
</div>
