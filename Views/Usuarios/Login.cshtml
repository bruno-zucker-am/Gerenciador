@model ProjetosDB.Models.LoginViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-8 col-md-5 col-lg-4 card-form">
            <h3 class="text-center mb-4">Acesso ao Sistema</h3>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger p-2 small">@ViewBag.Erro</div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Usuário</label>
                    <input asp-for="Login" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Senha</label>
                    <div class="input-group">
                        <input asp-for="Senha" id="pwdLogin" type="password" class="form-control" required />
                        <button class="btn" type="button" onclick="togglePass('pwdLogin', 'iconLogin')">
                            <i id="iconLogin" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary mb-3">Entrar</button>
                </div>
            </form>

            <hr class="my-4">

            <div class="d-grid">
                <a href="/Usuarios/Create" class="btn btn-secondary">
                    Não tem conta? Cadastre-se
                </a>
            </div>
        </div>
    </div>
</div>
